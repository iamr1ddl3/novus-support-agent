OPENAI_API_KEY=your-openai-api-key-here

# Project A RAG API URL (ADR-8: policy_kb tool calls Project A for vector retrieval)
# Local dev: start Project A with `uvicorn api:app --port 8080` first
# ECS prod:  set to Project A's ALB DNS name
RAG_API_URL=http://localhost:8080

# pgvector (Project B — port 5434)
PG_HOST=localhost
PG_PORT=5434
PG_USER=novus
PG_PASSWORD=novus123
PG_DATABASE=novus_support

# LangFuse (optional — for observability traces)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com
